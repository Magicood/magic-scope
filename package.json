{
  "name": "magic-scope",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "可发布到 npm 的多框架 UI 组件库 + 自动化收录流水线(主题:魔法)",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --passWithNoTests",
    "new": "tsx scripts/new-component.ts",
    "registry": "tsx registry/build-index.ts",
    "gen:docs-tokens": "tsx scripts/gen-docs-tokens.ts",
    "docs:dev": "pnpm gen:docs-tokens && vitepress dev docs",
    "docs:build": "pnpm gen:docs-tokens && vitepress build docs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "play": "vite playground",
    "gen:props": "tsx scripts/extract-props.ts",
    "check:props": "tsx scripts/extract-props.ts --check",
    "check:showcase": "tsx scripts/check-showcase.ts",
    "check:docs": "pnpm check:props && pnpm check:showcase",
    "showcase:coverage": "tsx scripts/showcase-coverage.ts",
    "showcase:sync": "pnpm gen:props && pnpm showcase:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6",
    "zod": "^4.4.3"
  }
}
