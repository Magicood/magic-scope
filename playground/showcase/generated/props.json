    {
      "name": "separator",
      "type": "ReactNode",
      "default": "/",
      "description": "项间分隔符,装饰性(aria-hidden)。默认 \"/\"。",
      "required": false
    },
    {
      "name": "className",
      "type": "string",
      "default": "—",
      "description": "外部类名(作用于 <nav>)。",
      "required": false
    }
  ],
  "Button": [
    {
      "name": "variant",
      "type": "\"solid\" | \"outline\" | \"ghost\"",
      "default": "solid",
      "description": "视觉变体:实底(带奥术发光)/ 描边 / 幽灵。默认 solid。",
      "required": false
    },
    {
      "name": "size",
      "type": "\"sm\" | \"md\" | \"lg\"",
      "default": "md",
      "description": "尺寸。默认 md。",
      "required": false
    }
  ],
  "Card": [
    {
      "name": "variant",
      "type": "\"outline\" | \"elevated\"",
      "default": "elevated",
      "description": "视觉变体:elevated(surface 底 + 柔和阴影)/ outline(透明底 + 描边)。默认 elevated。",
      "required": false
    },
    {
      "name": "interactive",
      "type": "boolean",
      "default": "false",
      "description": "可交互:true 时 hover 上浮 + 奥术发光,并暴露键盘聚焦环(tabIndex/focus-visible)。",
      "required": false
    }
  ],
  "Checkbox": [
    {
      "name": "children",
      "type": "ReactNode",
      "default": "—",
      "description": "复选框右侧的文字标签内容。",
      "required": false
    },
    {
      "name": "indeterminate",
      "type": "boolean",
      "default": "false",
      "description": "半选(部分选中)态:仅视觉,不改变 checked 取值。常用于「全选」框。",
      "required": false
    }
  ],
  "ContextMenu": [
    {
      "name": "items",
      "type": "MenuItem[]",
      "default": "—",
      "description": "菜单项列表(与 Menu 同结构)。",
