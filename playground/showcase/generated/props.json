{
  "Accordion": [
    {
      "name": "type",
      "type": "\"single\" | \"multiple\"",
      "default": "single",
      "description": "single:同时只展开一项;multiple:可同时展开多项。默认 single。",
      "required": false
    },
    {
      "name": "items",
      "type": "AccordionItem[]",
      "default": "—",
      "description": "面板项列表。",
      "required": true
    },
    {
      "name": "defaultValue",
      "type": "string | string[]",
      "default": "—",
      "description": "初始展开值。single 取 string,multiple 取 string[];宽松接受任一形态。",
      "required": false
    },
    {
      "name": "className",
      "type": "string",
      "default": "—",
      "description": "外部类名(作用于根容器)。",
      "required": false
    }
  ],
  "Alert": [
    {
      "name": "variant",
      "type": "\"info\" | \"success\" | \"warning\" | \"danger\"",
      "default": "info",
      "description": "语义变体:信息 / 成功 / 警告 / 危险。默认 info。",
      "required": false
    }
  ],
  "Avatar": [
    {
      "name": "size",
      "type": "\"sm\" | \"md\" | \"lg\"",
      "default": "md",
      "description": "尺寸。默认 md。",
      "required": false
    },
    {
      "name": "shape",
      "type": "\"circle\" | \"square\"",
      "default": "circle",
      "description": "形状:圆形 / 方形。默认 circle。",
      "required": false
