    {
      "name": "children",
      "type": "ReactNode",
      "default": "—",
      "description": "响应右键的区域内容。",
      "required": true
    },
    {
      "name": "className",
      "type": "string",
      "default": "—",
      "description": "菜单浮层附加类名。",
      "required": false
    }
  ],
  "Dialog": [
    {
      "name": "open",
      "type": "boolean",
      "default": "—",
      "description": "是否打开(受控)。",
      "required": true
    },
    {
      "name": "onClose",
      "type": "(() => void)",
      "default": "—",
      "description": "关闭时回调(Esc / 点击遮罩 / 原生 close)。",
