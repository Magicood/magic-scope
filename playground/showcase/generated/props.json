    {
      "name": "dismissable",
      "type": "boolean",
      "default": "true",
      "description": "点击遮罩是否关闭。默认 true。",
      "required": false
    }
  ],
  "Divider": [
    {
      "name": "orientation",
      "type": "\"horizontal\" | \"vertical\"",
      "default": "horizontal",
      "description": "朝向:水平(横跨容器宽度)/ 垂直(贴满容器高度,行内)。默认 horizontal。",
      "required": false
    }
  ],
  "Drawer": [
    {
      "name": "open",
      "type": "boolean",
      "default": "—",
      "description": "是否打开(受控)。",
      "required": true
    },
    {
      "name": "onClose",
      "type": "(() => void)",
      "default": "—",
      "description": "关闭时回调(Esc / 点击遮罩 / 关闭按钮)。",
      "required": false
    },
    {
      "name": "side",
      "type": "\"start\" | \"end\" | \"top\" | \"bottom\"",
      "default": "end",
      "description": "滑入边:start(左)/ end(右,默认)/ top / bottom。",
      "required": false
    },
    {
      "name": "title",
      "type": "ReactNode",
      "default": "—",
      "description": "标题(可选);设置后渲染头部并与抽屉 aria-labelledby 关联。",
      "required": false
    },
    {
      "name": "dismissable",
      "type": "boolean",
      "default": "true",
      "description": "点击遮罩是否关闭。默认 true。",
      "required": false
    }
  ],
  "Input": [
    {
      "name": "size",
      "type": "\"sm\" | \"md\" | \"lg\"",
      "default": "md",
      "description": "尺寸。默认 md。(覆盖原生 size 数值属性为尺寸枚举)",
