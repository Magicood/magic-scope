    {
      "name": "name",
      "type": "string",
      "default": "—",
      "description": "用户名。无 src 时取首字母(大写,最多 2 字)作为占位;同时用于无障碍标签。",
      "required": false
    }
  ],
  "Badge": [
    {
      "name": "variant",
      "type": "\"solid\" | \"soft\" | \"outline\"",
      "default": "soft",
      "description": "视觉变体:实底 / 柔和底 / 描边。默认 soft。",
      "required": false
    },
    {
      "name": "tone",
      "type": "\"success\" | \"warning\" | \"danger\" | \"primary\" | \"accent\" | \"neutral\"",
      "default": "primary",
      "description": "语义色调。默认 primary。neutral 走中性的 fg-muted / border。",
      "required": false
    }
  ],
  "Breadcrumb": [
    {
      "name": "items",
      "type": "BreadcrumbItem[]",
      "default": "—",
      "description": "面包屑层级项,自前往后。",
      "required": true
