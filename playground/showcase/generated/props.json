    {
      "name": "invalid",
      "type": "boolean",
      "default": "false",
      "description": "校验失败态:染 danger 色并设 aria-invalid。",
      "required": false
    }
  ],
  "Kbd": [
    {
      "name": "size",
      "type": "\"sm\" | \"md\"",
      "default": "md",
      "description": "尺寸:sm 紧凑 / md 默认。",
      "required": false
    }
  ],
  "Label": [
    {
      "name": "children",
      "type": "ReactNode",
      "default": "—",
      "description": "标签文字内容。",
      "required": false
    },
    {
      "name": "required",
      "type": "boolean",
      "default": "false",
      "description": "必填标记:在文末追加视觉星号(仅 aria-hidden 装饰;真正的必填语义由表单控件的 aria-required 承担)。",
      "required": false
    }
  ],
  "Menu": [
    {
      "name": "trigger",
      "type": "ReactElement<unknown, string | JSXElementConstructor<any>>",
      "default": "—",
      "description": "触发元素(通常是 Button)。点击展开菜单。",
      "required": true
    },
    {
      "name": "items",
      "type": "MenuItem[]",
      "default": "—",
      "description": "菜单项列表。",
      "required": true
    },
    {
      "name": "className",
      "type": "string",
      "default": "—",
      "description": "外部类名(作用于浮层)。",
      "required": false
    }
  ],
  "NumberInput": [
    {
      "name": "value",
