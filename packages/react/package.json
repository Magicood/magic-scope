{
  "name": "@magic-scope/react",
  "version": "0.1.1",
  "description": "magic-scope React 组件包(魔法主题)",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "ui",
    "components",
    "component-library",
    "design-system",
    "accessible",
    "css-variables",
    "magic-scope"
  ],
  "homepage": "https://github.com/Magicood/magic-scope/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/Magicood/magic-scope/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@magic-scope/tokens": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Magicood/magic-scope.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
