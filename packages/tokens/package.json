{
  "name": "@magic-scope/tokens",
  "version": "0.1.1",
  "description": "magic-scope 设计 token 与主题引擎(魔法主题,深色奥术默认预设)",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "design-tokens",
    "design-system",
    "theme",
    "theming",
    "css-variables",
    "oklch",
    "dark-theme",
    "magic-scope"
  ],
  "homepage": "https://github.com/Magicood/magic-scope/tree/main/packages/tokens#readme",
  "bugs": {
    "url": "https://github.com/Magicood/magic-scope/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./contract": {
      "import": {
        "types": "./dist/contract.d.ts",
        "default": "./dist/contract.js"
      },
      "require": {
        "types": "./dist/contract.d.cts",
        "default": "./dist/contract.cjs"
      }
    },
    "./engine": {
      "import": {
        "types": "./dist/engine.d.ts",
        "default": "./dist/engine.js"
      },
      "require": {
        "types": "./dist/engine.d.cts",
        "default": "./dist/engine.cjs"
      }
    },
    "./themes": {
      "import": {
        "types": "./dist/themes.d.ts",
        "default": "./dist/themes.js"
      },
      "require": {
        "types": "./dist/themes.d.cts",
        "default": "./dist/themes.cjs"
      }
    },
    "./derive": {
      "import": {
        "types": "./dist/derive.d.ts",
        "default": "./dist/derive.js"
      },
      "require": {
        "types": "./dist/derive.d.cts",
        "default": "./dist/derive.cjs"
      }
    },
    "./css/arcane.css": "./dist/css/arcane.css"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Magicood/magic-scope.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "access": "public"
  }
}
