{
  "name": "@magic-scope/tokens",
  "version": "0.0.0",
  "description": "magic-scope 设计 token 与主题引擎(魔法主题,深色奥术默认预设)",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "import": "./dist/contract.js",
      "require": "./dist/contract.cjs"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js",
      "require": "./dist/engine.cjs"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js",
      "require": "./dist/themes.cjs"
    },
    "./derive": {
      "types": "./dist/derive.d.ts",
      "import": "./dist/derive.js",
      "require": "./dist/derive.cjs"
    },
    "./css/arcane.css": "./dist/css/arcane.css"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  }
}
